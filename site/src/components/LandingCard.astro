---
interface Props {
  title: string;
  description: string;
  href: string;
  accentColor: string;
  badge?: string;
  external?: boolean;
  icon: string;
  appStoreUrl?: string;
  appSubdomain?: string;
  blogPost?: string;
  primarySubdomain?: string;
  externalUrl?: string;
}

const { title, description, href, accentColor, badge, external, icon, appStoreUrl, appSubdomain, blogPost, primarySubdomain, externalUrl } = Astro.props;
const hasActions = !!(appStoreUrl || appSubdomain || blogPost || externalUrl);
---

<div
  class="landing-card group relative overflow-hidden rounded-lg bg-[var(--color-bg-elevated)] border border-[var(--color-translucent)] transition-all duration-300 hover:scale-[1.02] hover:shadow-lg"
>
  <!-- Accent bar -->
  <div
    class="absolute left-0 top-0 bottom-0 w-1 transition-all duration-300 group-hover:w-1.5"
    style={`background-color: ${accentColor};`}
  ></div>

  <div class="pl-5 pr-4 py-4">
    <div class="flex items-start gap-3">
      <!-- Icon -->
      <div
        class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center"
        style={`background-color: ${accentColor}20;`}
      >
        <svg
          class="w-5 h-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          style={`color: ${accentColor};`}
        >
          <path d={icon} />
        </svg>
      </div>

      <!-- Content -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <!-- Primary link stretched over entire card -->
          <a
            href={href}
            class:list={['primary-link', { 'subdomain-primary': !!primarySubdomain }]}
            {...(primarySubdomain ? { 'data-subdomain-primary': primarySubdomain } : {})}
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <h3
              class="text-base font-semibold text-[var(--color-heading)] transition-colors truncate"
              style={`--hover-color: ${accentColor};`}
            >
              <span class="group-hover:text-[var(--hover-color)] transition-colors">
                {title}
              </span>
            </h3>
          </a>
          {badge && (
            <span
              class="flex-shrink-0 px-1.5 py-0.5 text-[var(--color-dark)] rounded text-[10px] font-semibold uppercase tracking-wide"
              style={`background-color: ${accentColor};`}
            >
              {badge}
            </span>
          )}
        </div>
        <p class="text-sm text-[var(--color-text-muted)] mt-0.5 line-clamp-1">
          {description}
        </p>

        {hasActions && (
          <div class="flex items-center gap-2 mt-2">
            {appStoreUrl && (
              <a
                href={appStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="action-btn inline-flex items-center gap-1 px-2 py-1 rounded text-[11px] font-medium text-[var(--color-text-muted)] bg-[var(--color-translucent)] hover:text-[var(--color-heading)] hover:bg-[var(--color-bg)] transition-colors"
                title="View on App Store"
              >
                <!-- Apple logo -->
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
                App Store
              </a>
            )}
            {appSubdomain && (
              <a
                data-subdomain={appSubdomain}
                class="action-btn app-link inline-flex items-center gap-1 px-2 py-1 rounded text-[11px] font-medium text-[var(--color-text-muted)] bg-[var(--color-translucent)] hover:text-[var(--color-heading)] hover:bg-[var(--color-bg)] transition-colors"
                title="Open live app"
              >
                <!-- External link icon -->
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Open
              </a>
            )}
            {blogPost && (
              <a
                href={blogPost}
                class="action-btn inline-flex items-center gap-1 px-2 py-1 rounded text-[11px] font-medium text-[var(--color-text-muted)] bg-[var(--color-translucent)] hover:text-[var(--color-heading)] hover:bg-[var(--color-bg)] transition-colors"
                title="Read blog post"
              >
                <!-- Article icon -->
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                </svg>
                Blog
              </a>
            )}
            {externalUrl && (
              <a
                href={externalUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="action-btn inline-flex items-center gap-1 px-2 py-1 rounded text-[11px] font-medium text-[var(--color-text-muted)] bg-[var(--color-translucent)] hover:text-[var(--color-heading)] hover:bg-[var(--color-bg)] transition-colors"
                title="Visit"
              >
                <!-- External link icon -->
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Visit
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  /* Primary link stretches over the entire card */
  .primary-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  /* Action buttons sit above the stretched link */
  .action-btn {
    position: relative;
    z-index: 1;
  }

  /* Badge sits above stretched link for proper rendering */
  .landing-card span[class*="flex-shrink-0"] {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  // Helper: derive base domain from current hostname
  // e.g. 'www.dreamfold.dev' → 'dreamfold.dev', 'www.localhost' → 'localhost'
  function getBaseDomain() {
    const host = window.location.hostname;
    return host.replace(/^[^.]+\./, '') || host;
  }

  const protocol = window.location.protocol;
  const port = window.location.port ? `:${window.location.port}` : '';
  const baseDomain = getBaseDomain();

  // Resolve web app subdomain URLs for "Open" action buttons
  document.querySelectorAll('.app-link[data-subdomain]').forEach((el) => {
    const link = el as HTMLAnchorElement;
    const subdomain = link.dataset.subdomain;
    if (!subdomain) return;

    link.href = `${protocol}//${subdomain}.${baseDomain}${port}`;
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
  });

  // Resolve primary card links that target a subdomain (e.g. Blog → blog.localhost)
  document.querySelectorAll('.subdomain-primary[data-subdomain-primary]').forEach((el) => {
    const link = el as HTMLAnchorElement;
    const subdomain = link.dataset.subdomainPrimary;
    if (!subdomain) return;

    link.href = `${protocol}//${subdomain}.${baseDomain}${port}`;
  });
</script>
