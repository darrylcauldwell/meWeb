---
import ThemeToggle from './ThemeToggle.astro';
import SearchWidget from './SearchWidget.astro';
---

<header class="bg-[var(--color-bg-header)] text-[var(--color-header-text-active)] sticky top-0 z-50">
  <nav class="max-w-[var(--max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo — links to landing page (base domain) -->
      <a href="/" id="home-link" class="text-xl font-bold hover:text-[var(--color-accent)] transition-colors">
        dreamfold.dev
      </a>

      <!-- Right-side controls -->
      <div class="flex items-center gap-2">
        <SearchWidget />
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<script>
  // Resolve home link to landing page (base domain)
  // e.g. from blog.dreamfold.dev → dreamfold.dev
  // e.g. from blog.localhost → localhost
  const homeLink = document.getElementById('home-link') as HTMLAnchorElement;
  if (homeLink) {
    const host = window.location.hostname;
    const parts = host.split('.');
    // If on a subdomain (2+ parts for real domains, or sub.localhost), link to base domain
    // For 'localhost' alone or bare domain, '/' already works
    if (parts.length > 1 && parts[parts.length - 1] !== 'localhost') {
      // Real domain: blog.dreamfold.dev → dreamfold.dev
      const baseDomain = parts.slice(-2).join('.');
      const port = window.location.port ? `:${window.location.port}` : '';
      homeLink.href = `${window.location.protocol}//${baseDomain}${port}/`;
    } else if (parts.length === 2 && parts[parts.length - 1] === 'localhost') {
      // Sub.localhost: blog.localhost → localhost
      const port = window.location.port ? `:${window.location.port}` : '';
      homeLink.href = `${window.location.protocol}//localhost${port}/`;
    }
    // Otherwise (bare localhost or bare domain), '/' is already correct
  }
</script>
