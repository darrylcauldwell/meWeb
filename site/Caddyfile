# Global options
{
    email {$ACME_EMAIL:}
    servers {
        metrics
    }
}

# Shared config for static site server blocks
(static_site_common) {
    root * /srv
    file_server
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @static {
        path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html {
        path *.html
    }
    header @html Cache-Control "public, max-age=3600, must-revalidate"

    respond /healthz 200 {
        body "healthy"
        close
    }

    try_files {path} {path}/ {path}.html
}

# Main blog site
{$SITE_ADDRESS::80} {
    import static_site_common

    # Grafana reverse proxy
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # Prometheus reverse proxy
    handle /prometheus/* {
        reverse_proxy prometheus:9090
    }

    # Custom 404 page
    handle_errors {
        @404 {
            expression {http.error.status_code} == 404
        }
        rewrite @404 /404.html
        file_server
    }
}

# Landing page (www / bare domain)
{$WWW_ADDRESS:www.localhost} {
    import static_site_common
    rewrite / /www/index.html
}

# CV page
{$CV_ADDRESS:cv.localhost} {
    import static_site_common
    rewrite / /cv/index.html
}

# Bio page
{$BIO_ADDRESS:bio.localhost} {
    import static_site_common
    rewrite / /bio/index.html
}

# Presentations
{$PRESENTATIONS_ADDRESS:presentations.localhost} {
    import static_site_common
    rewrite / /presentations/index.html
}

# Observability (needs grafana/prometheus proxies for JS fetches)
{$OBSERVABILITY_ADDRESS:observability.localhost} {
    import static_site_common
    rewrite / /observability/index.html

    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    handle /prometheus/* {
        reverse_proxy prometheus:9090
    }
}

# GreenScope - Software Carbon Intensity dashboard
{$SCI_ADDRESS:sci.localhost} {
    reverse_proxy greenscope:8000
}

# ntfy push notification service
{$NTFY_ADDRESS:ntfy.localhost} {
    reverse_proxy ntfy:80
}

# Planespotter application
{$PLANESPOTTER_ADDRESS:planespotter.localhost} {
    # Health check (must be handle block for proper routing)
    handle /healthz {
        respond 200 {
            body "healthy"
            close
        }
    }

    # API routes
    handle /api/* {
        reverse_proxy planespotter-api:8000
    }

    # Frontend (default - includes /health observability page)
    handle {
        reverse_proxy planespotter-frontend:8080
    }
}

# Equestrian Venue Manager
{$EVM_ADDRESS:evm.localhost} {
    # Health check (must be handle block for proper routing)
    handle /healthz {
        respond 200 {
            body "healthy"
            close
        }
    }

    # API routes
    handle /api/* {
        reverse_proxy evm-backend:8000
    }

    # Frontend (default)
    handle {
        reverse_proxy evm-frontend:80
    }
}

# EquiCalendar - Equestrian competition calendar
{$EQUICALENDAR_ADDRESS:equicalendar.localhost} {
    reverse_proxy equicalendar:8000
}

# App Support Site (TableTogether, etc.)
{$SUPPORT_ADDRESS:support.localhost} {
    root * /srv/support
    file_server
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @static {
        path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    try_files {path} {path}/ {path}.html {path}/index.html

    respond /healthz 200 {
        body "healthy"
        close
    }
}

