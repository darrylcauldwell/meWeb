# Global options
{
    email {$ACME_EMAIL:}
    servers {
        metrics
    }
}

# Shared config for static site server blocks
(static_site_common) {
    root * /srv
    file_server
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @static {
        path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html {
        path *.html
    }
    header @html Cache-Control "public, max-age=3600, must-revalidate"

    respond /healthz 200 {
        body "healthy"
        close
    }

    try_files {path} {path}/ {path}.html
}

# Landing page (bare domain / www — fallback for unmatched hosts locally)
{$SITE_ADDRESS::80} {
    import static_site_common
    rewrite / /www/index.html

    # Proxies needed for observability page JS health checks
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    handle /prometheus/* {
        reverse_proxy prometheus:9090
    }

    # Custom 404 page
    handle_errors {
        @404 {
            expression {http.error.status_code} == 404
        }
        rewrite @404 /404.html
        file_server
    }
}

# Landing page (www subdomain)
{$WWW_ADDRESS:http://www.localhost} {
    import static_site_common
    rewrite / /www/index.html

    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    handle /prometheus/* {
        reverse_proxy prometheus:9090
    }
}

