# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update values for your deployment.
# =============================================================================

# Site configuration
SITE_ADDRESS=dreamfold.dev
SUPPORT_ADDRESS=support.dreamfold.dev
ACME_EMAIL=your-email@example.com

# Subdomain routing
WWW_ADDRESS=www.dreamfold.dev
BLOG_ADDRESS=blog.dreamfold.dev
CV_ADDRESS=cv.dreamfold.dev
BIO_ADDRESS=bio.dreamfold.dev
PRESENTATIONS_ADDRESS=presentations.dreamfold.dev
OBSERVABILITY_ADDRESS=observability.dreamfold.dev
SCI_ADDRESS=sci.dreamfold.dev
FINOPS_ADDRESS=finops.dreamfold.dev

# GitHub integration
GITHUB_USER=darrylcauldwell

# Notifications (ntfy)
NTFY_ADDRESS=ntfy.dreamfold.dev
NTFY_URL=https://ntfy.dreamfold.dev

# Planespotter
PLANESPOTTER_ADDRESS=planespotter.dreamfold.dev
PLANESPOTTER_DB_PASSWORD=your-secure-password
PLANESPOTTER_API_URL=http://planespotter-api:8000
LOG_LEVEL=INFO

# Equestrian Venue Manager
EVM_ADDRESS=evm.dreamfold.dev
EVM_DB_USER=evm
EVM_DB_PASSWORD=your-secure-password
EVM_DB_NAME=evm_db
EVM_SECRET_KEY=your-secret-key
EVM_ACCESS_TOKEN_EXPIRE=30
EVM_REFRESH_TOKEN_EXPIRE=7
EVM_STRIPE_SECRET_KEY=
EVM_STRIPE_WEBHOOK_SECRET=

# EquiCalendar
EQUICALENDAR_ADDRESS=equicalendar.dreamfold.dev
EQUICALENDAR_HOME_POSTCODE=your-home-postcode
EQUICALENDAR_API_KEY=your-api-key
EQUICALENDAR_ANALYTICS_DOMAIN=

# VCF Green Insight - Embodied Carbon Calculator
VCF_GREEN_INSIGHT_ADDRESS=vcf-green.dreamfold.dev

# GreenScope - Software Carbon Intensity
GREENSCOPE_PROMETHEUS_URL=http://prometheus:9090/prometheus
GREENSCOPE_HOST_TDP_WATTS=205
GREENSCOPE_HOST_CORES=2
GREENSCOPE_HOST_PUE=1.2
GREENSCOPE_HOST_EMBODIED_CO2_KG=1205.52
GREENSCOPE_HOST_LIFESPAN_YEARS=4
GREENSCOPE_APP_BOUNDARIES={"evm": ["evm-backend", "evm-frontend", "evm-db"], "equicalendar": ["equicalendar"], "planespotter": ["planespotter-api", "planespotter-frontend", "planespotter-sync", "planespotter-db", "planespotter-cache"], "meweb": ["meweb"], "greenscope": ["greenscope"], "vcf-green-insight": ["vcf-green-insight"]}
GREENSCOPE_APP_REQUEST_JOBS={"evm": "evm-backend", "equicalendar": "equicalendar", "planespotter": "planespotter-api", "meweb": "caddy", "greenscope": "greenscope", "vcf-green-insight": "vcf-green-insight"}
GREENSCOPE_APP_DISPLAY_NAMES={"evm": "Equestrian Venue Manager", "equicalendar": "EquiCalendar", "planespotter": "Planespotter", "meweb": "dreamfold.dev", "greenscope": "GreenScope", "vcf-green-insight": "VCF Green Insight"}
GREENSCOPE_DATACENTER_POSTCODE=SL1
GREENSCOPE_CALCULATION_INTERVAL_MINUTES=15

# Showback - FinOps Cost Allocation
SHOWBACK_PROMETHEUS_URL=http://prometheus:9090/prometheus
SHOWBACK_DROPLET_COST=24.00
SHOWBACK_CLOUDFLARE_COST=0.00
SHOWBACK_DOMAIN_COST=1.02
SHOWBACK_APP_BOUNDARIES={"evm": ["evm-backend", "evm-frontend", "evm-db"], "equicalendar": ["equicalendar"], "planespotter": ["planespotter-api", "planespotter-frontend", "planespotter-sync", "planespotter-db", "planespotter-cache"], "meweb": ["meweb"], "greenscope": ["greenscope"], "vcf-green-insight": ["vcf-green-insight"], "infrastructure": ["prometheus", "grafana", "loki", "promtail", "node-exporter", "cadvisor", "ntfy", "showback"]}
SHOWBACK_APP_DISPLAY_NAMES={"evm": "Equestrian Venue Manager", "equicalendar": "EquiCalendar", "planespotter": "Planespotter", "meweb": "dreamfold.dev", "greenscope": "GreenScope", "vcf-green-insight": "VCF Green Insight", "infrastructure": "Infrastructure"}
SHOWBACK_CALCULATION_INTERVAL_MINUTES=15
